          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{idToken}}" }],
            "url": { "raw": "{{baseUrl}}/requests", "host": ["{{baseUrl}}"], "path": ["requests"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200',    () => pm.response.to.have.status(200));",
            "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));",
            "pm.test('Has 1 request', () => pm.expect(pm.response.json().length).to.be.above(0));"
          ]}}]
