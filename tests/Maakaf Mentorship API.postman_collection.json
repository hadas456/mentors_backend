              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{idToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/mentees/me", "host": ["{{baseUrl}}"], "path": ["mentees","me"] },
            "body": { "mode": "raw", "raw": "{\n  \"experienceLevel\": \"intermediate\",\n  \"interests\": [\"React\", \"Node.js\", \"Open Source\"],\n  \"goals\": \"לעבוד בחברת סטארטאפ\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200',         () => pm.response.to.have.status(200));",
            "pm.test('Updated level',      () => pm.expect(pm.response.json().experienceLevel).to.equal('intermediate'));"
          ]}}]
        }

      ]
    },

    {
      "name": "📋 Requests",
      "item": [

        {
          "name": "Switch to Mentee Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"test.mentee@maakaf-test.dev\",\n  \"password\": \"Test1234!\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "const d = pm.response.json();",
