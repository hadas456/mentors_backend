          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200',    () => pm.response.to.have.status(200));",
            "pm.test('Has interests', () => pm.expect(pm.response.json().interests).to.be.an('array'));"
          ]}}]
        },

        {
          "name": "Update My Mentee Profile",
