# ─── Local development ────────────────────────────────────────────────────────

# Path to Firebase service account key file
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Base URL for email links
SITE_URL=http://localhost:1313

# Server port (defaults to 3000)
PORT=3000

# ─── Production / CI ──────────────────────────────────────────────────────────

# Paste the full service account JSON inline instead of using a key file
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Production base URL for email links
# SITE_URL=https://your-production-domain.com

# Port is usually provided by the hosting platform; override only if needed
# PORT=8080

# ─── All environments ─────────────────────────────────────────────────────────

# Firebase Web API key (Firebase console > Project settings > General)
FIREBASE_API_KEY=your-firebase-api-key

# Gmail account used as the email sender
GMAIL_USER=donotreplymkf@gmail.com

# Gmail API OAuth2 credentials (console.cloud.google.com → Gmail API → OAuth2)
GMAIL_CLIENT_ID=xxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=xxxx
GMAIL_REFRESH_TOKEN=xxxx
