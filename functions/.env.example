# ─── Firebase ─────────────────────────────────────────────────────────────────

# Path to Firebase service account key file (local dev)
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# OR paste the full service account JSON inline (production / CI)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Firebase Web API key (Firebase console → Project settings → General)
FIREBASE_API_KEY=your-firebase-api-key

# ─── Server ───────────────────────────────────────────────────────────────────

# Base URL of the frontend — used in email links and CORS
SITE_URL=http://localhost:1313
# SITE_URL=https://maakaf.com   ← production value

# Allowed CORS origin (defaults to SITE_URL if not set)
CORS_ORIGIN=http://localhost:1313
# CORS_ORIGIN=https://maakaf.com   ← production value

# Port (Railway provides this automatically; only override locally if needed)
# PORT=3000

# ─── Gmail API (OAuth2) ───────────────────────────────────────────────────────
# Create an OAuth2 client at console.cloud.google.com with the Gmail API enabled,
# then generate a refresh token via the OAuth2 Playground.

GMAIL_USER=donotreplymkf@gmail.com
GMAIL_CLIENT_ID=xxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=xxxx
GMAIL_REFRESH_TOKEN=xxxx

# ─── Development / Testing ────────────────────────────────────────────────────

# Suppress outgoing emails — OTPs and notifications log to console instead.
# Set in local dev to avoid sending real emails during development.
# Do NOT set in production.
# DISABLE_EMAILS=true

# Enables test-only API endpoints (/auth/dev/cleanup, /auth/dev/peek-otp).
# Required for the Postman collection to run fully automated.
# Do NOT set in production.
# ENABLE_DEV_ENDPOINTS=true
